# Optional — enables Google + magic-link sign-in and cloud progress sync.
# Without these the app works fully with local (per-browser) progress.
# Copy to `.env` for local dev, and add the same two as GitHub repo secrets
# (Settings → Secrets and variables → Actions) for the deployed site.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
